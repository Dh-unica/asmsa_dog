{#
/**
 * @file
 * Override of region--header-nav.html.twig to add the .overlay div
 * required by Bootstrap Italia NavBarCollapsible component.
 *
 * @see template_preprocess_region()
 *
 * @ingroup themeable
 */
#}
{% apply spaceless %}
  {% if content %}
    {% set _header_nav_id = region~'-main-navbar' %}

    {% set attributes = attributes
      .addClass([
        'navbar',
        'navbar-expand-' ~ navigation_header_breakpoint_expand ?: 'lg',
        'has-megamenu'
      ])
    %}

    <div{{ attributes }}>
      <button
        class="custom-navbar-toggler"
        type="button"
        aria-label="{{ 'Show/hide navigation bar'|t }}"
        aria-controls="{{ _header_nav_id }}"
        data-bs-toggle="navbarcollapsible"
        data-bs-target="#{{ _header_nav_id }}"
        data-focus-mouse="false"
        aria-expanded="false"
      >
        <span>
          {% block togglerIcon %}
            {% include '@bi-bcl/icon/icon.html.twig' with {
              name: 'it-burger',
              color: 'white',
              icon_title: 'Show/hide navigation bar'|t
            } %}
          {% endblock %}
        </span>
      </button>
      <div id="{{ _header_nav_id }}" class="navbar-collapsable">
        <div class="overlay"></div>
        {% block closeMenuButton %}
          <div class="close-div">
            <button class="btn close-menu" type="button" aria-label="{{ 'Hide navigation'|t }}">
              <span>
              {% include '@bi-bcl/icon/icon.html.twig' with {
                name: 'it-close-big',
                icon_title: 'Hide navigation bar'|t
              } %}</span>
            </button>
          </div>
        {% endblock %}
        <div class="menu-wrapper d-lg-flex">
          {% block menuContent %}
            {{ content }}
          {% endblock %}
        </div>
      </div>
    </div>
  {% endif %}
{% endapply %}
